http {
    upstream backend {
        server 127.0.0.1:8081 weight=1;
        server 127.0.0.1:8082 weight=1;
        server 127.0.0.1:8083 weight=1;
    }

    server {
        listen 80;
        location / {
            proxy_pass http://backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }
    }
}